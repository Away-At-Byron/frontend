# Away at Byron Bay PMS — copy to .env.local for local dev. Never commit .env.local.

# Database (local docker-compose.dev.yml defaults)
DATABASE_URL=postgres://aab:aab_local@localhost:5432/aab_dev

# Auth.js v5
# generate: bun -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=aab
S3_SECRET_KEY=aab_local_dev_only
S3_BUCKET=aab-dev

# Email — console transport in dev, smtp (Postal) in prod
EMAIL_TRANSPORT=console
EMAIL_FROM="Away at Byron Bay <noreply@awayatbyron.local>"

# Error tracking (GlitchTip / Sentry-compatible) — optional in dev
SENTRY_DSN=

# pg-boss
PGBOSS_SCHEMA=pgboss

# ID-document encryption key (AES-256, 32 bytes base64). Dev-only sample below.
# generate: bun -e "console.log(crypto.getRandomValues(Buffer.alloc(32)).toString('base64'))"
ID_ENCRYPTION_KEY=
