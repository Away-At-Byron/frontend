{
  "name": "away-at-byron-pms",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:studio": "drizzle-kit studio",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:seed": "bun run src/db/seed/run.ts",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d && sleep 3 && bun drizzle:migrate && bun db:seed"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hookform/resolvers": "^3.9.1",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@tanstack/react-table": "^8.20.5",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.4",
    "lucide-react": "^0.460.0",
    "next": "^16.0.0",
    "next-auth": "5.0.0-beta.25",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.13.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
